{
  "name": "@pfeiferio/ref",
  "version": "1.0.0",
  "description": "Minimal mutable reference primitive with change notifications",
  "license": "MIT",
  "author": "Pascal Pfeifer <pascal@pfeifer.zone>",
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ref",
    "state",
    "mutable",
    "reference",
    "events",
    "primitive",
    "signals",
    "reactive"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pfeiferio/ref.git"
  },
  "bugs": {
    "url": "https://github.com/pfeiferio/ref/issues"
  },
  "homepage": "https://github.com/pfeiferio/ref#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "npm test",
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-exclude='test/**'",
    "test:coverage:c8": "npm run build && npx c8 node --test",
    "test:coverage:lcov": "npm run build && npx c8 --src src node --enable-source-maps --test"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
