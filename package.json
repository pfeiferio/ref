{
  "name": "@pfeiferio/ref",
  "version": "0.1.0",
  "description": "Minimal mutable reference primitive with change notifications",
  "license": "MIT",
  "author": "Pascal Pfeifer <pascal@pfeifer.zone>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ref",
    "state",
    "mutable",
    "reference",
    "events",
    "primitive",
    "signals",
    "reactive"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pfeiferio/ref.git"
  },
  "bugs": {
    "url": "https://github.com/pfeiferio/ref/issues"
  },
  "homepage": "https://github.com/pfeiferio/ref#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test",
    "test:watch": "node --test --watch",
    "test:coverage": "npm run build && node --test --experimental-test-coverage",
    "prepublishOnly": "npm run clean && npm test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.17.9",
    "typescript": "^5.9.3"
  }
}
